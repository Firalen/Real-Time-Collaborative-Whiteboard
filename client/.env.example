# =============================================================================
# CollabBoard — Client environment variables (Vite)
# Copy to client/.env:  cp client/.env.example client/.env
#
# Rebuild/redeploy after changes — Vite embeds these at build time.
# =============================================================================

# REST API base URL (no trailing slash)
VITE_API_URL=http://localhost:3001

# Socket.IO server URL — usually the same as VITE_API_URL
VITE_SOCKET_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Production example (Vercel / Netlify)
# -----------------------------------------------------------------------------
# VITE_API_URL=https://your-api.railway.app
# VITE_SOCKET_URL=https://your-api.railway.app
