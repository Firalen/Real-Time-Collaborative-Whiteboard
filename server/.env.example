# =============================================================================
# CollabBoard — Server environment variables
# Copy to server/.env:  cp server/.env.example server/.env
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

PORT=3001
NODE_ENV=development

# PostgreSQL (docker-compose default below)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whiteboard

# JWT signing secret — MUST change in production (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-in-production-use-long-random-string

# Frontend origin — CORS, invite links, Stripe checkout redirects
# Production: https://your-app.vercel.app  (no trailing slash)
# Multiple origins: comma-separated
CLIENT_URL=http://localhost:5173

# Extra allowed origins (comma-separated), e.g. custom domain
# ALLOWED_ORIGINS=https://www.yourdomain.com

# Set to false to block *.vercel.app preview URLs (default: allow)
# ALLOW_VERCEL_PREVIEWS=true

# -----------------------------------------------------------------------------
# Recommended for production
# -----------------------------------------------------------------------------

# Redis — socket/session scaling across multiple server instances
# Local (with docker compose): redis://localhost:6379
# REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Optional — Billing (Stripe)
# -----------------------------------------------------------------------------
# Checkout fails without STRIPE_SECRET_KEY. Price IDs live in the database, not here.
# After creating products in Stripe Dashboard, run:
#   UPDATE subscription_plans SET stripe_price_monthly_id = 'price_...', stripe_price_annual_id = 'price_...' WHERE slug = 'pro';
# STRIPE_SECRET_KEY=sk_test_xxxxxxxx

# -----------------------------------------------------------------------------
# Optional — AI (OpenAI)
# -----------------------------------------------------------------------------
# Required for AI mind maps, image generation, and other /api/.../ai routes
# OPENAI_API_KEY=sk-xxxxxxxx
# OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Optional — Email (workspace invitations)
# -----------------------------------------------------------------------------
# Without SMTP, invite emails are logged to the server console in development
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-smtp-password-or-api-key
# SMTP_FROM=CollabBoard <noreply@yourdomain.com>

# -----------------------------------------------------------------------------
# Optional — File uploads (board images / assets)
# -----------------------------------------------------------------------------
# UPLOAD_DIR=./uploads
# Public base URL for asset links in production (e.g. https://api.yourdomain.com/uploads)
# UPLOAD_PUBLIC_URL=https://your-api.railway.app/uploads
