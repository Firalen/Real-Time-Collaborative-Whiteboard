PORT=3001
NODE_ENV=development

# PostgreSQL (Railway provides this in production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whiteboard

# Redis — leave unset for local dev without Docker; set on Railway
# REDIS_URL=redis://localhost:6379

# JWT secret — use a long random string in production
JWT_SECRET=change-me-in-production-use-long-random-string

# Frontend URL for CORS (Vercel URL in production)
CLIENT_URL=http://localhost:5173

# Email (optional — logs to console in dev without SMTP)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Whiteboard <noreply@yourdomain.com>
